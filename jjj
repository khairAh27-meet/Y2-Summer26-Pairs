import os
from urllib.parse import quote
from anthropic import Anthropic
from dotenv import load_dotenv

load_dotenv()


# ------------------------
# Your function (kept)
# ------------------------
def user_info():
    location = input("Where are you travelling? ")
    activity = input("What are you interested in - activity? ")
    budget = int(input("What's your budget? "))

    return location, activity, budget


# ------------------------
# Google Maps function (added)
# ------------------------
def google_maps_link(place):
    return f"https://www.google.com/maps/search/{quote(place)}"


# ------------------------
# Claude setup
# ------------------------
client = Anthropic(api_key=os.getenv('ANTHROPIC_API_KEY'))


def run_chat():

    print('You: (type exit to quit)')

    system_message = '''

Your job is to provide real answers and don't make ones up unless you are asked to.

You have access to a Google Maps tool.
When the user asks about a location, restaurant, attraction, hotel, or place:
- use the google_maps_link function to provide a Google Maps link.

Rules:
- Always be creative
- Always be helpful
- Never make up facts unless asked to

Response format:
- Start with a one-sentence summary of what the user said.
- Then give your response.
- End with one follow-up question.
'''

    history = []

    while True:

        user_input = input('>> ')

        if user_input.lower() == 'exit':
            break


        # Call Google Maps when user mentions a place
        if any(word in user_input.lower() for word in 
               ["where", "place", "restaurant", "hotel", "visit", "location", "map"]):

            map_link = google_maps_link(user_input)

            user_input += f"""

Here is a Google Maps link for this place:
{map_link}
"""


        history.append({
            'role': 'user',
            'content': user_input
        })


        response = client.messages.create(
            model='claude-haiku-4-5-20251001',
            max_tokens=300,
            temperature=0.7,
            system=system_message,
            messages=history
        )


        reply = response.content[0].text

        print(f'Claude: {reply}')

        history.append({
            'role': 'assistant',
            'content': reply
        })


run_chat()